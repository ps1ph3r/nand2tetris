/**
 * The Hack Central Processing unit (CPU).
 * Parses the binary code in the instruction input and executes it according to the
 * Hack machine language specification. In the case of a C-instruction, computes the
 * function specified by the instruction. If the instruction specifies to read a memory
 * value, the inM input is expected to contain this value. If the instruction specifies
 * to write a value to the memory, sets the outM output to this value, sets the addressM
 * output to the target address, and asserts the writeM output (when writeM = 0, any
 * value may appear in outM).
 * If the reset input is 0, computes the address of the next instruction and sets the
 * pc output to that value. If the reset input is 1, sets pc to 0.
 * Note: The outM and writeM outputs are combinational: they are affected by the
 * instruction's execution during the current cycle. The addressM and pc outputs are
 * clocked: although they are affected by the instruction's execution, they commit to
 * their new values only in the next cycle.
 */
CHIP CPU {

    IN  inM[16],         // M value input  (M = contents of RAM[A])
        instruction[16], // Instruction for execution
        reset;           // Signals whether to re-start the current
                         // program (reset==1) or continue executing
                         // the current program (reset==0).

    OUT outM[16],        // M value output
        writeM,          // Write to M? 
        addressM[15],    // Address in data memory (of M)
        pc[15];          // address of next instruction

    PARTS:
    // A or C instruction with dest bit including A
	Mux16(a[0..14]=instruction[0..14] , b=aluOut , sel=instruction[15] , out=aRegIn );
    
    // C-instruction and the dest bits include A
    And(a=instruction[15] , b=instruction[5] , out=cInsDestA );    

    // A-instruction
    Not(in=instruction[15] , out=aIns );

    // load bit for ARegister
    Or(a=aIns , b=cInsDestA , out=aInsORcInsDestA );

    ARegister(in=aRegIn , load=aInsORcInsDestA , out=aRegOut, out[0..14]=addressM );    

    // A or M
    Mux16(a=aRegOut , b=inM , sel=instruction[12] , out=aRegOrM );

    // C ins with dest bits including D
    And(a=instruction[15] , b=instruction[4] , out=cInsDestD );    
    DRegister(in=aluOut , load=cInsDestD , out=dRegOut );

    ALU(x=dRegOut , y=aRegOrM , zx=instruction[11] , nx=instruction[10] , zy=instruction[9] , ny=instruction[8] , f=instruction[7] , no=instruction[6] , out=aluOut, out=outM , zr=zrOut , ng=ngOut );


    // JGT
    Not(in=zrOut, out=zrNot);
    Not(in=ngOut, out=ngNot);
    And(a=zrNot, b=ngNot, out=positive);
    And(a=instruction[0] , b=positive , out=jgt );
    
    // JEQ
    And(a=instruction[1] , b=zrOut , out=jeq );

    // JGE
    Or(a=positive , b=zrOut , out=positiveORzero );
    And(a=instruction[0] , b=instruction[1] , out=geJmpBits );
    And(a=geJmpBits , b=positiveORzero , out=jge );
    
    // JLT
    And(a=instruction[2] , b=ngOut , out=jlt );

    // JNE
    Or(a=positive , b=ngOut , out=notZero );
    And(a=instruction[0] , b=instruction[2] , out=neJmpBits );
    And(a=notZero , b=neJmpBits , out=jne );

    // JLE
    Or(a=ngOut , b=zrOut , out=negativeORZero );
    And(a=instruction[1] , b=instruction[2] , out=leJmpBits );
    And(a=leJmpBits , b=negativeORZero , out=jle );

    // JMP
    And(a=instruction[0] , b=instruction[1] , out=temp );
    And(a=temp , b=instruction[2] , out=jmp );

    // Or-ing all the jmp flags
    Or(a=jgt, b=jeq, out=tmp1);
    Or(a=jge, b=jlt, out=tmp2);
    Or(a=jne, b=jle, out=tmp3);
    Or(a=tmp1, b=tmp2, out=tmp4);
    Or(a=tmp3, b=jmp, out=tmp5);
    Or(a=tmp4, b=tmp5, out=tempPCLoad);

    // C-ins and Jmp 
    And(a=instruction[15] , b=tempPCLoad , out=pcLoad );

    PC(in=aRegOut , load=pcLoad , inc=true , reset=reset , out[0..14]=pc );

    // WriteM
    And(a=instruction[15] , b=instruction[3] , out=writeM );
}